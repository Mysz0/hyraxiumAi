# Required
TELEGRAM_TOKEN=your_bot_token_from_botfather
OWNER_TELEGRAM_ID=your_telegram_user_id   # get it from @userinfobot

# Ollama — defaults assume standard Docker bridge on Linux
OLLAMA_HOST=http://172.17.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# CONTEXT_WINDOW_SIZE=128000   # lower this for smaller models (e.g. 8192 for 8k-context models)

# Web search via SearXNG — leave empty to disable
# SEARXNG_HOST=http://172.17.0.1:8080

# Bot identity
BOT_NAME=Hyrax

# Memory
MEMORY_DIR=/memory

# Proactive messages per day (0–10, 0 to disable)
PROACTIVE_MAX_PER_DAY=2

# ── macOS local dev ──────────────────────────────────────────────────
# Remove network_mode: host from docker-compose.yml, then use:
# OLLAMA_HOST=http://host.docker.internal:11434
# SEARXNG_HOST=http://host.docker.internal:8080
